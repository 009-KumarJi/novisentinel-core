# Copy to .env and edit. Defaults are dev-safe; change MASTER_API_KEY for prod.

# --- Gateway ---
# The master API key used to authenticate all API calls.
# REQUIRED in production: must not be the placeholder value below.
# The app refuses to start in non-dev mode if this is set to the dev default.
MASTER_API_KEY=change-me-to-a-long-random-string

# --- Database ---
# PostgreSQL connection URL (DSN with asyncpg driver).
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@postgres:5432/novisentinel

# --- Redis ---
# Used for the sliding-window rate limiter and async task queuing.
REDIS_URL=redis://redis:6379

# --- ML Models ---
# spaCy model for PII and named-entity recognition.
SPACY_MODEL=en_core_web_lg
# HuggingFace model for prompt-injection classification.
INJECTION_MODEL=protectai/deberta-v3-base-prompt-injection-v2
# Confidence threshold (0–1) above which a span is flagged as injection.
INJECTION_THRESHOLD=0.85

# --- Rate Limiting ---
# Maximum number of API requests per minute per API key (sliding window).
DEFAULT_RATE_LIMIT_RPM=120

# --- Toxicity Detection ---
# Set to false to disable the toxicity detector entirely.
TOXICITY_ENABLED=true
# Model variant: "original" (default), "unbiased", or "multilingual".
TOXICITY_MODEL=original
# Confidence thresholds for each severity band (0–1).
TOXICITY_THRESHOLD_SEVERE=0.5
TOXICITY_THRESHOLD_HIGH=0.7
TOXICITY_THRESHOLD_MEDIUM=0.8
