# Copy to .env and fill in the keys for the providers you use.
# At least one provider key is required to proxy requests.

# ── Provider API keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Detectors ─────────────────────────────────────────────────────────────────
# spaCy model for PII / NER
SPACY_MODEL=en_core_web_lg

# HuggingFace model for prompt-injection classification
INJECTION_MODEL=protectai/deberta-v3-base-prompt-injection-v2
INJECTION_THRESHOLD=0.85

# Detoxify toxicity detection (set TOXICITY_ENABLED=false to disable)
TOXICITY_ENABLED=true
TOXICITY_MODEL=original
TOXICITY_THRESHOLD_SEVERE=0.5
TOXICITY_THRESHOLD_HIGH=0.7
TOXICITY_THRESHOLD_MEDIUM=0.8

# ── Custom detectors (optional) ───────────────────────────────────────────────
# Comma-separated URLs of custom HTTP detector endpoints.
# Each endpoint receives POST {"text": "..."} and returns {"label": "BLOCK|ALLOW", "score": 0.0-1.0}.
# CUSTOM_DETECTOR_ENDPOINTS=https://your-detector.example.com/scan
# CUSTOM_DETECTOR_SECRETS=optional-secret-per-endpoint

# ── Server ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# CORS_ORIGINS=["*"]
